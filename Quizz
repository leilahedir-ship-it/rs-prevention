<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#111111">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<title>Quiz Securite RS TRANSPORT</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif;background:#111;min-height:100vh}
#app{width:100%;max-width:430px;margin:0 auto;min-height:100vh;background:#111;overflow-x:hidden;position:relative}
.scr{display:none}
.scr.on{display:block}
#cov{background:#111;min-height:100vh;position:relative;overflow:hidden}
.split{position:absolute;bottom:0;right:0;width:55%;height:50%;background:#E30613;-webkit-clip-path:polygon(35% 0,100% 0,100% 100%,0 100%);clip-path:polygon(35% 0,100% 0,100% 100%,0 100%)}
.dots{position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.05) 1px,transparent 1px);background-size:22px 22px}
.cov-in{position:relative;z-index:1;padding:56px 24px 48px;min-height:100vh;display:flex;flex-direction:column}
.cov-logo{width:110px;height:auto;display:block;margin-bottom:36px}
.badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:100px;padding:5px 13px;font-size:10px;font-weight:700;letter-spacing:1.5px;color:rgba(255,255,255,.8);text-transform:uppercase;margin-bottom:20px}
.badge::before{content:"";width:5px;height:5px;border-radius:50%;background:#E30613;display:inline-block}
.cov-h{font-size:34px;font-weight:800;color:#fff;line-height:1.15;margin-bottom:10px}
.cov-h em{color:#E30613;font-style:normal}
.cov-p{font-size:13px;color:rgba(255,255,255,.5);line-height:1.6;margin-bottom:32px}
.stats{display:flex;gap:10px;margin-bottom:auto;padding-bottom:32px}
.stat{flex:1;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:12px 8px;text-align:center}
.stat-n{font-size:22px;font-weight:800;color:#fff}
.stat-l{font-size:9px;font-weight:600;color:rgba(255,255,255,.4);letter-spacing:1px;text-transform:uppercase;margin-top:2px}
.btn-go{background:#E30613;color:#fff;border:none;border-radius:14px;padding:17px;font-size:15px;font-weight:800;width:100%;cursor:pointer;letter-spacing:.2px;display:block;-webkit-appearance:none}
.btn-go:active{background:#b8050f}
#qz{background:#f5f5f3;min-height:100vh}
.qhd{background:#111;padding:14px 16px 16px;position:sticky;top:0;z-index:2}
.qhd-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.qcnt{font-size:11px;font-weight:600;color:rgba(255,255,255,.5)}
.qsc{background:#E30613;color:#fff;font-size:10px;font-weight:700;padding:3px 10px;border-radius:100px}
.prog{height:3px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden}
.prog-f{height:3px;background:#E30613;border-radius:3px;transition:width .4s ease}
.qbody{padding:16px}
.qcat{font-size:9px;font-weight:700;letter-spacing:2px;color:#E30613;text-transform:uppercase;margin-bottom:8px}
.qtxt{font-size:15.5px;font-weight:700;color:#111;line-height:1.4;margin-bottom:16px}
.opts{display:flex;flex-direction:column;gap:8px;margin-bottom:12px}
.opt{display:flex;align-items:center;gap:12px;background:#fff;border:1.5px solid #e6e4e1;border-radius:12px;padding:13px 14px;font-size:13.5px;font-weight:600;color:#222;text-align:left;width:100%;cursor:pointer;-webkit-appearance:none;min-height:52px}
.opt:active{opacity:.85}
.ol{width:28px;height:28px;min-width:28px;border-radius:50%;background:#f0eeeb;border:1.5px solid #ddd;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#888;flex:none}
.opt.ok{background:#eef8e4;border-color:#3a880d}
.opt.ok .ol{background:#3a880d;border-color:#3a880d;color:#fff}
.opt.ko{background:#fef1f1;border-color:#bb1919}
.opt.ko .ol{background:#bb1919;border-color:#bb1919;color:#fff}
.opt.hnt{background:#eef8e4;border-color:#3a880d;opacity:.7}
.opt.hnt .ol{background:#3a880d;border-color:#3a880d;color:#fff}
.opt.dim{opacity:.3;pointer-events:none}
.fb{border-radius:12px;padding:12px 14px;margin-bottom:12px;display:none;border-left:3px solid transparent}
.fb.on{display:block}
.fb-h{display:flex;align-items:center;gap:8px;margin-bottom:4px}
.fb-ic{width:20px;height:20px;min-width:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;flex:none}
.fb-lb{font-size:12px;font-weight:700}
.fb-tx{font-size:11.5px;line-height:1.55}
.fb.ok{background:#eef8e4;border-left-color:#3a880d}
.fb.ok .fb-ic{background:#3a880d;color:#fff}
.fb.ok .fb-lb{color:#1a5202}
.fb.ok .fb-tx{color:#255608}
.fb.ko{background:#fef1f1;border-left-color:#bb1919}
.fb.ko .fb-ic{background:#bb1919;color:#fff}
.fb.ko .fb-lb{color:#7a0f0f}
.fb.ko .fb-tx{color:#8a1a1a}
.btn-nx{display:none;width:100%;background:#111;color:#fff;border:none;border-radius:12px;padding:15px;font-size:13.5px;font-weight:700;cursor:pointer;-webkit-appearance:none}
.btn-nx.on{display:block}
.btn-nx:active{background:#333}
#res{background:#f5f5f3;min-height:100vh}
.rhd{background:#111;padding:24px 20px 28px;text-align:center}
.r-med{font-size:46px;margin-bottom:10px}
.r-tit{font-size:21px;font-weight:800;color:#fff;margin-bottom:3px}
.r-sub{font-size:12px;color:rgba(255,255,255,.45)}
.r-ring{display:flex;justify-content:center;margin:20px 0 14px}
.r-ring-in{position:relative;width:136px;height:136px}
.r-stw{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.r-sn{font-size:30px;font-weight:800;color:#111}
.r-sd{font-size:12px;color:#aaa;font-weight:500}
.r-sp{font-size:11px;color:#E30613;font-weight:600}
.rbody{padding:0 16px 16px}
.r-card{background:#fff;border-radius:14px;border:1px solid #e6e4e1;padding:14px;margin-bottom:14px}
.r-ct{font-size:14px;font-weight:700;color:#111;margin-bottom:3px}
.r-cs{font-size:12px;color:#666;line-height:1.5}
.s-lbl{font-size:9px;font-weight:700;letter-spacing:1.5px;color:#aaa;text-transform:uppercase;margin-bottom:8px}
.catblk{margin-bottom:14px}
.crow{display:flex;align-items:center;gap:8px;margin-bottom:5px}
.cl{font-size:11px;font-weight:600;color:#333;width:96px;min-width:96px}
.cbw{flex:1;height:5px;background:#e6e4e1;border-radius:5px;overflow:hidden}
.cbar{height:5px;border-radius:5px;width:0;transition:width .9s ease}
.csco{font-size:11px;font-weight:700;width:26px;text-align:right}
.rc-it{display:flex;align-items:flex-start;gap:8px;background:#fff;border-radius:10px;border:1px solid #eee;padding:10px 12px;margin-bottom:6px}
.rc-ic{width:18px;height:18px;min-width:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:900;flex:none;margin-top:1px}
.rc-ic.ok{background:#3a880d;color:#fff}
.rc-ic.ko{background:#bb1919;color:#fff}
.rc-ct{font-size:8px;font-weight:700;letter-spacing:1px;color:#E30613;text-transform:uppercase;margin-bottom:1px}
.rc-q{font-size:11px;font-weight:600;color:#333;line-height:1.35}
.rc-ans{font-size:10.5px;color:#255608;background:#eef8e4;border-radius:5px;padding:3px 7px;margin-top:3px;display:inline-block}
.rbtns{padding:0 16px 36px;display:flex;flex-direction:column;gap:8px}
.btn-rs{background:#E30613;color:#fff;border:none;border-radius:14px;padding:16px;font-size:14px;font-weight:700;cursor:pointer;-webkit-appearance:none;width:100%}
.btn-rs:active{background:#b8050f}
.btn-sh{background:#fff;color:#111;border:1.5px solid #e6e4e1;border-radius:14px;padding:14px;font-size:13px;font-weight:600;cursor:pointer;-webkit-appearance:none;width:100%}
.btn-sh:active{background:#f0eeeb}
.cf-wrap{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:hidden;z-index:5}
.cf-p{position:absolute}
@-webkit-keyframes cf{0%{-webkit-transform:translateY(-10px) rotate(0deg);opacity:1}100%{-webkit-transform:translateY(110vh) rotate(540deg);opacity:0}}
@keyframes cf{0%{transform:translateY(-10px) rotate(0deg);opacity:1}100%{transform:translateY(110vh) rotate(540deg);opacity:0}}
</style>
</head>
<body>
<div id="app">

<div id="cov" class="scr on">
  <div class="split"></div>
  <div class="dots"></div>
  <div class="cov-in">
    <img class="cov-logo" src="data:image/png;base64," alt="RS Transport">
    <span class="badge">Securite au travail</span>
    <h1 class="cov-h">Quiz<br><em>Prevention</em><br>Securite</h1>
    <p class="cov-p">Testez vos connaissances sur les regles essentielles de securite RS TRANSPORT. Questions et reponses melangees a chaque partie.</p>
    <div class="stats">
      <div class="stat"><div class="stat-n">15</div><div class="stat-l">Questions</div></div>
      <div class="stat"><div class="stat-n">6</div><div class="stat-l">Themes</div></div>
      <div class="stat"><div class="stat-n">~5</div><div class="stat-l">Minutes</div></div>
    </div>
    <button type="button" id="btn-go" class="btn-go">Demarrer le quiz</button>
  </div>
  <div class="cf-wrap" id="cf"></div>
</div>

<div id="qz" class="scr">
  <div class="qhd">
    <div class="qhd-top"><span class="qcnt" id="cnt">Q 1 / 15</span><span class="qsc" id="sco">0 correct</span></div>
    <div class="prog"><div class="prog-f" id="pf" style="width:0%"></div></div>
  </div>
  <div class="qbody">
    <div class="qcat" id="qcat"></div>
    <div class="qtxt" id="qtxt"></div>
    <div class="opts" id="opts"></div>
    <div class="fb" id="fb">
      <div class="fb-h"><div class="fb-ic" id="fic"></div><div class="fb-lb" id="flb"></div></div>
      <div class="fb-tx" id="ftx"></div>
    </div>
    <button type="button" id="btn-nx" class="btn-nx">Question suivante</button>
  </div>
</div>

<div id="res" class="scr">
  <div class="rhd">
    <div class="r-med" id="rmed"></div>
    <div class="r-tit" id="rtit"></div>
    <div class="r-sub" id="rsub"></div>
  </div>
  <div class="r-ring">
    <div class="r-ring-in">
      <svg style="-webkit-transform:rotate(-90deg);transform:rotate(-90deg)" width="136" height="136" viewBox="0 0 136 136">
        <circle cx="68" cy="68" r="54" fill="none" stroke="#e6e4e1" stroke-width="10"/>
        <circle cx="68" cy="68" r="54" fill="none" id="rarc" stroke="#E30613" stroke-width="10" stroke-linecap="round" stroke-dasharray="339.3" stroke-dashoffset="339.3" style="-webkit-transition:stroke-dashoffset 1.3s ease;transition:stroke-dashoffset 1.3s ease"/>
      </svg>
      <div class="r-stw"><div class="r-sn" id="rsn">0</div><div class="r-sd" id="rsd">/15</div><div class="r-sp" id="rpc"></div></div>
    </div>
  </div>
  <div class="rbody">
    <div class="r-card"><div class="r-ct" id="rmsg"></div><div class="r-cs" id="rmsgs"></div></div>
    <div class="catblk"><div class="s-lbl">Score par theme</div><div id="cbars"></div></div>
    <div class="s-lbl">Recapitulatif</div><div id="rcap"></div>
  </div>
  <div class="rbtns">
    <button type="button" id="btn-rs" class="btn-rs">Recommencer le quiz</button>
    <button type="button" id="btn-sh" class="btn-sh">Partager mon score</button>
  </div>
</div>

</div>
<script>
var B=[
  {c:"EPI",q:"Quels equipements sont obligatoires lors du chargement et dechargement ?",o:["Casque et lunettes uniquement","Gilet haute visibilite, chaussures de securite et gants","Gants uniquement","Aucun equipement requis"],a:1,e:"Le gilet haute visibilite, les chaussures de securite et les gants sont obligatoires lors de toute operation de chargement/dechargement."},
  {c:"EPI",q:"Que faire si un EPI est abime ou manquant avant votre tournee ?",o:["Partir quand meme","L'acheter soi-meme","Le signaler immediatement au responsable","Utiliser l'EPI abime en attendant"],a:2,e:"Tout EPI manquant ou abime doit etre signale immediatement avant le depart. Ne jamais prendre la route sans equipements de protection intacts."},
  {c:"EPI",q:"Le gilet haute visibilite doit etre porte :",o:["Uniquement de nuit","Des la descente du vehicule sur tous les sites","Uniquement sur autoroute","Uniquement si le client l'exige"],a:1,e:"Le gilet doit etre porte des la descente du vehicule, sur tous les sites, de jour comme de nuit."},
  {c:"Avant la route",q:"Quel element est ABSENT de la checklist avant chaque tournee ?",o:["Verifier les niveaux moteur","Controler les pneus","Appeler ses collegues pour discuter","Verifier les equipements de secours a bord"],a:2,e:"Checklist : controle visuel, niveaux, carburant, eclairage, pneus, documents, equipements de secours (triangle, gilet, extincteur), telephone charge et adresse verifiee."},
  {c:"Avant la route",q:"Les equipements de secours obligatoires a bord sont :",o:["Triangle, gilet dans l'habitacle et extincteur","Gilet de sauvetage et bouee","Trousse de cereales et cosmetiques","Extincteur uniquement"],a:0,e:"Le triangle de presignalisation, le gilet haute visibilite dans l'habitacle et l'extincteur sont obligatoires a bord."},
  {c:"Avant la route",q:"Vos pneus semblent sous-gonfles avant le depart. Que faites-vous ?",o:["Partir quand meme","Les regonfler ou signaler le probleme avant de partir","Rouler doucement pour compenser","Verifier en roulant sur 500 metres"],a:1,e:"Un pneu sous-gonfle augmente le risque d'eclatement. Il faut regonfler ou signaler le probleme avant tout depart."},
  {c:"Manutention",q:"Quelle est la bonne posture pour soulever une charge lourde ?",o:["Se pencher en avant, dos arrondi","Plier les jambes et garder le dos droit","Tirer la charge depuis le sol","Soulever rapidement pour limiter l'effort"],a:1,e:"Plier les jambes, garder le dos droit, maintenir la charge proche du corps. Ne jamais arrondir le dos : 1ere cause de TMS chez les chauffeurs-livreurs."},
  {c:"Manutention",q:"Face a une charge trop lourde, que faites-vous ?",o:["Forcer, vous etes habitue","La faire glisser au sol","Demander de l'aide ou utiliser le materiel adapte","Attendre que quelqu'un passe"],a:2,e:"Ne jamais porter seul une charge trop lourde. Utiliser le transpalette, le diable ou demander de l'aide."},
  {c:"Pendant les livraisons",q:"Pour monter et descendre du vehicule, quelle regle s'applique ?",o:["Sauter directement pour gagner du temps","Utiliser les 3 points d'appui","Se tenir uniquement a la portiere","Courir pour limiter l'exposition"],a:1,e:"La regle des 3 points d'appui (2 mains + 1 pied ou 1 main + 2 pieds) est imperative pour eviter les chutes."},
  {c:"Pendant les livraisons",q:"En cas de retard dans les livraisons, vous devez :",o:["Courir entre les points","Rouler plus vite","Signaler au responsable et garder votre allure habituelle","Sauter des etapes de securite"],a:2,e:"Ne jamais courir ni rouler trop vite a cause d'un retard. La securite prime toujours sur les delais."},
  {c:"Conduite",q:"L'utilisation du telephone en conduisant est :",o:["Autorisee si c'est rapide","Autorisee uniquement en mains-libres","Totalement interdite, y compris en mains-libres","Autorisee a l'arret au feu rouge"],a:2,e:"L'utilisation du telephone est totalement interdite pendant la conduite, meme en mains-libres. Risque multiplie par 4."},
  {c:"Conduite",q:"Que devez-vous obligatoirement avoir a bord ?",o:["Rien, l'entreprise gere tout","Permis, carte grise, assurance et bons de livraison","Uniquement le bon de livraison","Uniquement le permis"],a:1,e:"Documents obligatoires : permis, carte grise, attestation d'assurance, bons de livraison."},
  {c:"Conduite",q:"Pourquoi respecter les temps de repos est-il crucial ?",o:["C'est uniquement administratif","La fatigue est l'une des 1eres causes d'accident","C'est pour economiser le carburant","Pour avoir plus de temps libre"],a:1,e:"La fatigue multiplie le risque d'accident par 3 et allonge le temps de reaction."},
  {c:"En cas d'accident",q:"Quel numero est indispensable en cas d'accident sur la voie publique ?",o:["Le 15 SAMU","Le 18 Pompiers","Le 17 Police / Gendarmerie","Le 112 suffit toujours"],a:2,e:"Le 17 (Police/Gendarmerie) est indispensable pour tout accident avec un tiers. A retenir : 15 SAMU, 17 Police, 18 Pompiers, 112 Urgences europeen."},
  {c:"En cas d'accident",q:"Les 3 infos cles a donner aux secours lors d'un appel d'urgence :",o:["Nom, age, numero de secu","Lieu precis, nature de l'accident, nombre de blesses","Heure, meteo et vitesse","Adresse domicile, employeur, immatriculation"],a:1,e:"Lors de tout appel : 1) lieu precis, 2) nature de l'accident, 3) nombre de blesses."},
  {c:"En cas d'accident",q:"Quelle est la sequence correcte en cas d'accident ?",o:["Appeler RS Transport en premier","Se proteger, Proteger, Alerter, Prevenir RS Transport, Declarer","Prendre des photos d'abord","Chercher des temoins avant d'appeler"],a:1,e:"1. Se proteger, 2. Proteger les autres, 3. Alerter les secours, 4. Prevenir RS Transport, 5. Completer la declaration."},
  {c:"Culture securite",q:"Vous constatez une situation dangereuse. Que faites-vous ?",o:["Ignorer, ce n'est pas votre role","Attendre que quelqu'un d'autre signale","Signaler immediatement a votre responsable","Regler ca seul sans en parler"],a:2,e:"Chaque chauffeur est acteur de la prevention. Signaler toute situation dangereuse protege tout le monde."},
  {c:"Culture securite",q:"Vous avez eu un presque-accident. Devez-vous le signaler ?",o:["Non, pas de blesse","Oui, pour analyser et eviter un vrai accident","Non, ca augmente votre sinistralite","Uniquement si des temoins l'ont vu"],a:1,e:"Signaler les presqu'accidents permet d'identifier les risques et d'agir avant qu'un vrai accident survienne."}
];

var Q=[],cur=0,sc=0,picked=false,res=[];
var NQ=15;

function sf(a){
  var b=a.slice();
  for(var i=b.length-1;i>0;i--){
    var j=Math.floor(Math.random()*(i+1));
    var t=b[i];b[i]=b[j];b[j]=t;
  }
  return b;
}

function show(id){
  var ids=["cov","qz","res"];
  for(var i=0;i<ids.length;i++){
    document.getElementById(ids[i]).className="scr"+(ids[i]===id?" on":"");
  }
  window.scrollTo(0,0);
}

function go(){
  var bank=sf(B.slice());
  Q=[];
  for(var i=0;i<NQ;i++){
    var q=bank[i];
    var ix=sf([0,1,2,3]);
    var no=[q.o[ix[0]],q.o[ix[1]],q.o[ix[2]],q.o[ix[3]]];
    var na=ix.indexOf(q.a);
    Q.push({c:q.c,q:q.q,o:no,a:na,e:q.e});
  }
  cur=0;sc=0;picked=false;res=[];
  show("qz");
  render();
}

function render(){
  var q=Q[cur];
  document.getElementById("cnt").textContent="Q "+(cur+1)+" / "+NQ;
  document.getElementById("sco").textContent=sc+" correct";
  document.getElementById("pf").style.width=Math.round(cur/NQ*100)+"%";
  document.getElementById("qcat").textContent=q.c;
  document.getElementById("qtxt").textContent=q.q;
  var el=document.getElementById("opts");
  el.innerHTML="";
  var L=["A","B","C","D"];
  for(var i=0;i<4;i++){
    var b=document.createElement("button");
    b.type="button";
    b.className="opt";
    var s1=document.createElement("span");s1.className="ol";s1.textContent=L[i];
    var s2=document.createElement("span");s2.textContent=q.o[i];
    b.appendChild(s1);b.appendChild(s2);
    b.setAttribute("data-i",""+i);
    b.addEventListener("click",pickHandler);
    el.appendChild(b);
  }
  document.getElementById("fb").className="fb";
  document.getElementById("btn-nx").className="btn-nx";
  picked=false;
}

function pickHandler(){pick(parseInt(this.getAttribute("data-i"),10));}

function pick(i){
  if(picked)return;
  picked=true;
  var q=Q[cur];
  var ok=(i===q.a);
  if(ok)sc++;
  res.push({ok:ok,c:q.c,q:q.q,ans:q.o[q.a]});
  var btns=document.querySelectorAll(".opt");
  for(var j=0;j<btns.length;j++){
    if(j===q.a){btns[j].className="opt "+(ok&&j===i?"ok":"hnt");}
    else if(j===i){btns[j].className="opt ko";}
    else{btns[j].className="opt dim";}
  }
  var fb=document.getElementById("fb");
  fb.className="fb on "+(ok?"ok":"ko");
  document.getElementById("fic").textContent=ok?"OK":"X";
  document.getElementById("flb").textContent=ok?"Bonne reponse !":"Pas tout a fait...";
  document.getElementById("ftx").textContent=q.e;
  var bn=document.getElementById("btn-nx");
  bn.className="btn-nx on";
  bn.textContent=(cur<NQ-1)?"Question suivante":"Voir mes resultats";
}

function nxt(){
  cur++;
  if(cur>=NQ){result();return;}
  render();
}

function confetti(){
  var w=document.getElementById("cf");
  w.innerHTML="";
  var cs=["#E30613","#3a880d","#f5a623","#111","#ffd700"];
  for(var i=0;i<60;i++){
    var p=document.createElement("div");
    p.className="cf-p";
    var sz=(5+Math.random()*9);
    p.style.width=sz+"px";p.style.height=sz+"px";
    p.style.left=Math.floor(Math.random()*100)+"%";
    p.style.top="0px";
    p.style.background=cs[Math.floor(Math.random()*5)];
    p.style.borderRadius=(Math.random()>.5?"50%":"2px");
    var dur=(1.2+Math.random()*1.5).toFixed(2)+"s";
    var del=(Math.random()*.8).toFixed(2)+"s";
    p.style.WebkitAnimation="cf "+dur+" "+del+" ease-in forwards";
    p.style.animation="cf "+dur+" "+del+" ease-in forwards";
    w.appendChild(p);
  }
  setTimeout(function(){w.innerHTML="";},4000);
}

function result(){
  show("res");
  var pct=Math.round(sc/NQ*100);
  var circ=2*Math.PI*54;
  var arc=document.getElementById("rarc");
  var col=(pct>=80?"#3a880d":(pct>=50?"#E30613":"#bb1919"));
  setTimeout(function(){
    arc.setAttribute("stroke",col);
    arc.style.strokeDashoffset=(circ-(circ*pct/100)).toFixed(1);
  },200);
  document.getElementById("rsn").textContent=sc;
  document.getElementById("rsd").textContent="/"+NQ;
  document.getElementById("rpc").textContent=pct+"%";
  var m,t,s,msg,msub;
  if(pct>=90){m="Excellent !";t="Vous maitrisez les regles de securite RS TRANSPORT.";msg="Felicitations, vous etes un acteur exemplaire de la prevention !";msub="Continuez a appliquer ces regles chaque jour.";setTimeout(confetti,500);}
  else if(pct>=70){m="Bon resultat !";t="Quelques points a consolider.";msg="Vous avez de bonnes bases en securite.";msub="Relisez le livret d'accueil sur les themes ou vous avez hesite.";}
  else if(pct>=50){m="Des lacunes a combler.";t="Une remise a niveau est recommandee.";msg="Certaines regles meritent d'etre mieux connues.";msub="Relisez le livret d'accueil avec votre chef d'equipe.";}
  else{m="Formation recommandee.";t="Vos connaissances doivent etre renforcees.";msg="Des lacunes importantes ont ete identifiees.";msub="Contactez votre responsable pour une remise a niveau securite.";}
  document.getElementById("rmed").textContent=(pct>=90?"Excellent":(pct>=70?"Bon resultat":(pct>=50?"A ameliorer":"Attention")));
  document.getElementById("rtit").textContent=m;
  document.getElementById("rsub").textContent=t;
  document.getElementById("rmsg").textContent=msg;
  document.getElementById("rmsgs").textContent=msub;
  var cats={};
  for(var k=0;k<res.length;k++){
    var r=res[k];
    if(!cats[r.c])cats[r.c]={ok:0,n:0};
    cats[r.c].n++;
    if(r.ok)cats[r.c].ok++;
  }
  var cb=document.getElementById("cbars");cb.innerHTML="";
  var keys=[];for(var key in cats)keys.push(key);
  for(var ci=0;ci<keys.length;ci++){
    var cat=keys[ci];var d=cats[cat];
    var p=Math.round(d.ok/d.n*100);
    var cc=(p===100?"#3a880d":(p>=50?"#E30613":"#bb1919"));
    var row=document.createElement("div");row.className="crow";
    row.innerHTML='<span class="cl">'+cat+'</span><span class="cbw"><span class="cbar" id="cb'+ci+'" style="background:'+cc+'"></span></span><span class="csco" style="color:'+cc+'">'+d.ok+"/"+d.n+"</span>";
    cb.appendChild(row);
    (function(id,pw){setTimeout(function(){var el=document.getElementById(id);if(el)el.style.width=pw+"%";},450);}("cb"+ci,p));
  }
  var rc=document.getElementById("rcap");rc.innerHTML="";
  for(var ri=0;ri<res.length;ri++){
    var rr=res[ri];
    var d2=document.createElement("div");d2.className="rc-it";
    var qs=(Q[ri].q.length>65?Q[ri].q.substring(0,65)+"...":Q[ri].q);
    d2.innerHTML='<div class="rc-ic '+(rr.ok?"ok":"ko")+'">'+(rr.ok?"v":"x")+'</div><div style="flex:1"><div class="rc-ct">'+Q[ri].c+'</div><div class="rc-q">'+qs+"</div>"+(rr.ok?"":'<span class="rc-ans">Bonne reponse : '+rr.ans+"</span>")+"</div>";
    rc.appendChild(d2);
  }
}

function restart(){
  var arc=document.getElementById("rarc");
  arc.style.WebkitTransition="none";arc.style.transition="none";
  arc.style.strokeDashoffset="339.3";arc.setAttribute("stroke","#E30613");
  setTimeout(function(){
    arc.style.WebkitTransition="stroke-dashoffset 1.3s ease";
    arc.style.transition="stroke-dashoffset 1.3s ease";
  },50);
  show("cov");
}

function shr(){
  var pct=Math.round(sc/NQ*100);
  var txt="Quiz Securite RS TRANSPORT : "+sc+"/"+NQ+" ("+pct+"%)";
  if(navigator.share){navigator.share({text:txt});}
  else if(navigator.clipboard){navigator.clipboard.writeText(txt).then(function(){alert("Score copie !");});}
  else{alert(txt);}
}

window.addEventListener("DOMContentLoaded",function(){
  document.getElementById("btn-go").addEventListener("click",go);
  document.getElementById("btn-nx").addEventListener("click",nxt);
  document.getElementById("btn-rs").addEventListener("click",restart);
  document.getElementById("btn-sh").addEventListener("click",shr);
});
</script>
</body>
